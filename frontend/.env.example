# API base URL
VITE_API_BASE_URL=http://localhost:3001/api
# Optional: override DAO contract address (or set addresses.sepolia in src/contracts/DAO.json)
# VITE_DAO_CONTRACT_ADDRESS=
# Optional: RPC when adding Sepolia in MetaMask / fallback
# VITE_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
# Optional: dedicated URL for read-only eth_call (defaults to publicnode; avoids MetaMask Infura quota)
# VITE_SEPOLIA_READ_RPC_URL=https://ethereum-sepolia.publicnode.com
